{
  "name": "@lumora/api",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../../.env tsx watch src/index.ts",
    "dev:worker": "DOTENV_CONFIG_PATH=../../.env tsx watch worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@fal-ai/client": "^1.7.1",
    "@hono/node-server": "^1.19.6",
    "@hono/zod-validator": "^0.7.5",
    "@lumora/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.65.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.7",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3",
    "together-ai": "^0.25.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.19.1",
    "@types/pg": "^8.15.6",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
